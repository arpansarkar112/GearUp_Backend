model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  role     Role
  status   UserStatus @default(ACTIVE)

  gearItems    GearItem[]
  rentalOrders RentalOrder[]
  reviews      Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
